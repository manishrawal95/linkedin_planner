# LLM Provider: gemini (default) or claude
LINKEDIN_LLM_PROVIDER=gemini

# Gemini API key (free tier: 15 RPM)
GEMINI_API_KEY=your-gemini-api-key

# Claude API key (optional, for higher-quality drafts)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Model overrides (optional)
# LINKEDIN_GEMINI_MODEL=gemini-2.5-pro
# LINKEDIN_CLAUDE_MODEL=claude-sonnet-4-5-20250929
# LINKEDIN_LLM_TEMPERATURE=0.7

# Database path (optional, defaults to backend/linkedin_data.db)
# LINKEDIN_SQLITE_PATH=backend/linkedin_data.db

# Server
LINKEDIN_HOST=127.0.0.1
LINKEDIN_PORT=8200

# LinkedIn OAuth (optional — needed for Post to LinkedIn feature)
# Get credentials at https://www.linkedin.com/developers/apps
# Redirect URI: http://localhost:8200/auth/linkedin/callback
# Required scopes: openid, profile, w_member_social
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
